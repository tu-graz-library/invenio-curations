msgid "The record has not been curated yet."
msgstr "Der Datensatz wurde noch nicht kuratiert."

#: invenio_curations/services/errors.py:29
msgid "A role with name '{name}' does not exist."
msgstr "Eine Rolle mit dem Namen „{name}“ existiert nicht."

